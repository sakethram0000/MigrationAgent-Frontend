    private async Task<bool> PollMigrationStatus(string jobId, HttpClient httpClient)
    {
        int maxPolls = 1200; // 20 minutes max
        int pollCount = 0;
        string previousProgress = string.Empty;
        string previousStatus = string.Empty;
        
        while (pollCount < maxPolls)
        {
            try
            {
                var statusResp = await httpClient.GetAsync($"/api/migration/status/{jobId}");
                if (statusResp.IsSuccessStatusCode)
                {
                    var statusJson = await statusResp.Content.ReadFromJsonAsync<Dictionary<string, object>>();
                    if (statusJson != null)
                    {
                        statusJson.TryGetValue("stage", out var stage);
                        statusJson.TryGetValue("step", out var stepVal);
                        statusJson.TryGetValue("status", out var status);
                        statusJson.TryGetValue("progress", out var progress);
                        statusJson.TryGetValue("result", out var result);
                        statusJson.TryGetValue("error", out var error);
                        string statusStr = status?.ToString() ?? "unknown";
                        string progressStr = progress?.ToString() ?? "";
                        var stageStr = stage?.ToString() ?? string.Empty;
                        if (stageStr == "migrating")
                        {
                            SetStep(3, !string.IsNullOrEmpty(progressStr) ? progressStr : "Migrating...");
                            SetActionStage(3);
                            if (!string.IsNullOrEmpty(progressStr) && progressStr.Contains("Migrating"))
                            {
                                SetActionStage(4);
                            }
                        }
                        else if (stageStr == "completed")
                        {
                            SetStep(3, "Transformation completed");
                            UpdateOutputStates(migrationDone: true);
                            SetActionStage(5);
                        }
                        
                        statusMessage = $"Migration: {progressStr}";
                        if (statusStr != previousStatus || progressStr != previousProgress)
                        {
                            terminalOutput += $"⏳ {progressStr}\n";
                            previousStatus = statusStr;
                            previousProgress = progressStr;
                            StateHasChanged();
                        }
                        
                        if (statusStr == "completed")
                        {
                            if (result is JsonElement resultElement && resultElement.ValueKind == JsonValueKind.Object)
                            {
                                resultElement.TryGetProperty("count", out var countElement);
                                if (countElement.ValueKind == JsonValueKind.Number)
                                    migratedCount = countElement.GetInt32();

                                // Store migrated files for detail view
                                if (resultElement.TryGetProperty("migrated", out var migratedEl) && migratedEl.ValueKind == JsonValueKind.Object)
                                {
                                    migratedFiles.Clear();
                                    dependencyMap.Clear();
                                    foreach (var prop in migratedEl.EnumerateObject())
                                    {
                                        migratedFiles[prop.Name] = prop.Value.GetString() ?? string.Empty;
                                        if (prop.Name.EndsWith(".csproj"))
                                        {
                                            var val = prop.Value.GetString() ?? string.Empty;
                                            if (val.Contains("PackageReference"))
                                            {
                                                var matches = System.Text.RegularExpressions.Regex.Matches(val, @"Include=""([^""]+)"" Version=""([^""]+)""");
                                                foreach (System.Text.RegularExpressions.Match m in matches)
                                                    dependencyMap[m.Groups[1].Value] = m.Groups[2].Value;
                                            }
                                        }
                                    }
                                }

                                // Store manual fixes from fixer agent
                                if (resultElement.TryGetProperty("manual_fixes", out var manualFixesEl) && manualFixesEl.ValueKind == JsonValueKind.Array)
                                {
                                    foreach (var fix in manualFixesEl.EnumerateArray())
                                    {
                                        var fixStr = fix.GetString();
                                        if (!string.IsNullOrEmpty(fixStr))
                                            findingsWarnings.Add(fixStr);
                                    }
                                }
                            }
                            terminalOutput += "✅ Migration completed successfully.\n";
                            findingsInfo.Add($"Migrated {migratedCount} files.");
                            SetActionStage(5);
                            StateHasChanged();
                            return true;
                        }
                        else if (statusStr == "failed")
                        {
                            string errorStr = error?.ToString() ?? "Unknown error";
                            terminalOutput += $"❌ Migration failed: {errorStr}\n";
                            findingsCritical.Add($"Migration failed: {errorStr}");
                            StateHasChanged();
                            return false;
                        }
                    }
                }
                else
                {
                    terminalOutput += $"Failed to get migration status: {statusResp.StatusCode}\n";
                }
            }
            catch (Exception ex)
            {
                terminalOutput += $"Error polling migration status: {ex.Message}\n";
            }
            
            await Task.Delay(1000); // Wait 1 second before polling again
            pollCount++;
        }
        
        if (pollCount >= maxPolls)
        {
            terminalOutput += "Migration timed out after 10 minutes.\n";
            findingsCritical.Add("Migration timed out.");
            statusMessage = "Migration timed out.";
            return false;
        }
        return false;
    }

    record UploadedFile(string Name, long Size);
    record StepItem(int N, string Name);
}

<script>
    window.downloadBlob = (blob, filename) => {
        const url = URL.createObjectURL(new Blob([blob]));
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    };
</script>
