    async Task FetchGithubRepo()
    {
        if (string.IsNullOrWhiteSpace(githubUrl)) return;
        isFetchingGithub = true;
        githubFetchStatus = string.Empty;
        githubFetchSuccess = false;
        StateHasChanged();
        try
        {
            var httpClient = HttpClientFactory.CreateClient("MigrationAgentAPI");
            var resp = await httpClient.PostAsJsonAsync("/api/files/upload-github", new { url = githubUrl });
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<Dictionary<string, object>>();
                if (json != null)
                {
                    json.TryGetValue("repo", out var repo);
                    json.TryGetValue("cs_files", out var csFiles);
                    githubFetchStatus = $"Fetched {repo} — {csFiles} C# files ready";
                    githubFetchSuccess = true;
                    // Add a dummy entry so Run Migration button enables
                    files.Clear();
                    files.Add(new UploadedFile(repo?.ToString() ?? "github-repo", 0));
                }
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                githubFetchStatus = $"Failed: {resp.StatusCode}";
                githubFetchSuccess = false;
            }
        }
        catch (Exception ex)
        {
            githubFetchStatus = $"Error: {ex.Message}";
            githubFetchSuccess = false;
        }
        finally
        {
            isFetchingGithub = false;
        }
    }

