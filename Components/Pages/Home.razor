    async Task<bool> UploadFilesAsync()
    {
        // GitHub tab — repo already fetched and extracted on backend, skip upload
        if (uploadTab == "github" && githubFetchSuccess)
        {
            terminalOutput += "Using GitHub repository already fetched.\n";
            return true;
        }

        if (!browserFiles.Any())
            return false;

        using var content = new MultipartFormDataContent();
        foreach (var file in browserFiles)
        {
            var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 100);
            content.Add(new StreamContent(stream), "files", file.Name);
        }

        var httpClient = HttpClientFactory.CreateClient("MigrationAgentAPI");
        var response = await httpClient.PostAsync("/api/files/upload", content);
        if (!response.IsSuccessStatusCode)
        {
            terminalOutput += $"Upload failed: {response.StatusCode} - {response.ReasonPhrase}\n";
            return false;
        }

        terminalOutput += "Files uploaded successfully.\n";
        return true;
    }

    async Task RunMigration()
    {
        if (files.Count == 0)
            return;

        isLoading = true;
        showNotConnected = false;
        statusMessage = "Uploading files...";
        terminalOutput = string.Empty;
        analysisSummary = string.Empty;
        validationSummary = string.Empty;
        reportSummary = string.Empty;
        migratedCount = 0;
        findingsCritical.Clear();
        findingsWarnings.Clear();
        findingsInfo.Clear();
        ResetExecutionState();

        if (!await UploadFilesAsync())
        {
            isLoading = false;
            return;
        }
        SetStep(1, "Upload completed");
        SetActionStage(1);

        var request = new { from_version = fromVersion, to_version = toVersion };

        try
        {
            statusMessage = "Analyzing code...";
            SetStep(2, "Analyzing code");
            SetActionStage(2);
            var httpClient = HttpClientFactory.CreateClient("MigrationAgentAPI");
            var analysisResp = await httpClient.PostAsJsonAsync("/api/migration/analyze", request);
            terminalOutput += $"Analysis status: {analysisResp.StatusCode}\n";
            StateHasChanged();
            if (analysisResp.IsSuccessStatusCode)
            {
                var analysisJson = await analysisResp.Content.ReadFromJsonAsync<Dictionary<string, object>>();
                if (analysisJson != null)
                {
                    analysisJson.TryGetValue("success", out var analysisSuccess);
                    analysisJson.TryGetValue("error", out var analysisError);
                    analysisJson.TryGetValue("analysis", out var analysisResponse);
                    analysisSummary = analysisResponse?.ToString() ?? analysisError?.ToString() ?? string.Empty;
                    if (analysisSuccess is bool aok && aok)
                    {
                        terminalOutput += $"✅ Analysis completed successfully.\n";
                        terminalOutput += $"📊 Files analyzed. Complexity and breaking changes identified.\n";
                        findingsInfo.Add("Analysis completed.");
                        statusMessage = "Analysis completed.";
                        StateHasChanged();
                    }
                }
            }

            statusMessage = "Starting migration...";
            SetStep(3, "Transforming code");
            SetActionStage(3);
            var migrateResp = await httpClient.PostAsJsonAsync("/api/migration/migrate", request);
            terminalOutput += $"Migration started: {migrateResp.StatusCode}\n";
            StateHasChanged();
            if (migrateResp.IsSuccessStatusCode)
            {
                var migrateJson = await migrateResp.Content.ReadFromJsonAsync<Dictionary<string, object>>();
                if (migrateJson != null)
                {
                    migrateJson.TryGetValue("job_id", out var jobIdObj);
                    var jobIdStr = jobIdObj?.ToString();
                    if (!string.IsNullOrEmpty(jobIdStr))
                    {
                        terminalOutput += $"Migration job started with ID: {jobIdStr}\n";
                        
                        // Poll for migration status
                        var migrationSucceeded = await PollMigrationStatus(jobIdStr, httpClient);
                        if (!migrationSucceeded)
                        {
                            statusMessage = "Migration failed or timed out.";
                            isLoading = false;
                            return;
                        }
                        SetStep(3, "Transformation completed");
                        UpdateOutputStates(migrationDone: true);
                    }
                    else
                    {
                        terminalOutput += "Failed to get migration job ID.\n";
                        findingsCritical.Add("Migration failed: No job ID received.");
                    }
                }
            }

            statusMessage = "Validating output...";
            SetStep(4, "Validating output");
            SetActionStage(4);
            var validateResp = await httpClient.PostAsJsonAsync("/api/migration/validate", new {});
                    terminalOutput += $"Validation status: {validateResp.StatusCode}\n";
                    StateHasChanged();
            if (validateResp.IsSuccessStatusCode)
            {
                var validateJson = await validateResp.Content.ReadFromJsonAsync<Dictionary<string, object>>();
                if (validateJson != null)
                {
                    validateJson.TryGetValue("success", out var validateSuccess);
                    validateJson.TryGetValue("error", out var validationError);
                    validateJson.TryGetValue("errors", out var validationErrors);
                    validateJson.TryGetValue("output", out var validationOut);
                    var errorStr = validationError?.ToString() ?? string.Empty;
                    validationOutput = validationOut?.ToString() ?? errorStr;

                    // dotnet not installed — treat as skipped not failed
                    if (errorStr.Contains("dotnet CLI not found"))
                    {
                        validationSummary = "Build skipped.";
                        terminalOutput += "⚠️ Validation skipped: dotnet not installed on server. Download and build locally.\n";
                        findingsInfo.Add("Validation skipped — download project and run dotnet build locally.");
                        UpdateOutputStates(migrationDone: true, validationDone: true);
                        statusMessage = "Validation skipped.";
                        SetActionStage(4);
                    }
                    else if (validateSuccess is bool vok && vok)
                    {
                        validationSummary = "Build succeeded.";
                        terminalOutput += "✅ Validation completed — Build succeeded.\n";
                        findingsInfo.Add("Validation passed — build succeeded.");
                        UpdateOutputStates(migrationDone: true, validationDone: true);
                        reviewGateReady = true;
                        reviewGateMessage = "Review Gate ready";
                        statusMessage = "Validation completed.";
                        SetActionStage(4);
                    }
                    else
                    {
                        validationSummary = "Build failed.";
                        var errDetail = errorStr.Length > 0 ? errorStr : validationErrors?.ToString() ?? "Validation failed.";
                        findingsCritical.Add(errDetail);
                        terminalOutput += $"❌ Validation failed: {errDetail}\n";
                    }
                    StateHasChanged();
                }
            }

            statusMessage = "Generating report...";
            SetStep(5, "Packaging output");
            SetActionStage(5);
            UpdateOutputStates(migrationDone: true, validationDone: true);
            var reportResp = await httpClient.GetAsync("/api/migration/report");
                terminalOutput += $"Report status: {reportResp.StatusCode}\n";
                StateHasChanged();
            if (reportResp.IsSuccessStatusCode)
            {
                var reportJson = await reportResp.Content.ReadFromJsonAsync<Dictionary<string, object>>();
                if (reportJson != null)
                {
                    reportJson.TryGetValue("summary", out var summary);
                    reportSummary = summary?.ToString() ?? string.Empty;

                    // Recommendations -> findingsInfo
                    reportJson.TryGetValue("recommendations", out var recommendations);
                    if (recommendations is JsonElement recElement && recElement.ValueKind == JsonValueKind.Array)
                    {
                        foreach (var item in recElement.EnumerateArray())
                        {
                            if (item.ValueKind == JsonValueKind.String)
                                findingsInfo.Add(item.GetString() ?? string.Empty);
                        }
                    }

                    // Dependency map from report (fills gaps if polling missed any)
                    reportJson.TryGetValue("dependency_map", out var depMapObj);
                    if (depMapObj is JsonElement depMapEl && depMapEl.ValueKind == JsonValueKind.Object)
                    {
                        foreach (var prop in depMapEl.EnumerateObject())
                        {
                            if (!dependencyMap.ContainsKey(prop.Name))
                                dependencyMap[prop.Name] = prop.Value.GetString() ?? string.Empty;
                        }
                    }

                    // Manual fixes from report
                    reportJson.TryGetValue("manual_fixes", out var manualFixesObj);
                    if (manualFixesObj is JsonElement manualFixesEl && manualFixesEl.ValueKind == JsonValueKind.Array)
                    {
                        foreach (var item in manualFixesEl.EnumerateArray())
                        {
                            var fixStr = item.GetString();
                            if (!string.IsNullOrEmpty(fixStr) && !findingsWarnings.Contains(fixStr))
                                findingsWarnings.Add(fixStr);
                        }
                    }

                    // Issues -> findingsCritical
                    reportJson.TryGetValue("issues", out var issuesObj);
                    if (issuesObj is JsonElement issuesEl && issuesEl.ValueKind == JsonValueKind.Array)
                    {
                        foreach (var item in issuesEl.EnumerateArray())
                        {
                            if (item.ValueKind == JsonValueKind.String)
                                findingsCritical.Add(item.GetString() ?? string.Empty);
                        }
                    }
                }
                terminalOutput += "✅ Report generated successfully.\n";
                StateHasChanged();
                UpdateOutputStates(migrationDone: true, validationDone: true, reportDone: true);
                reviewGateReady = true;
                reviewGateMessage = "Review Gate ready — Migration complete";
                statusMessage = "Report generated.";
                SetActionStage(6);
            }
        }
        catch (Exception ex)
        {
            terminalOutput += $"Error: {ex.Message}\n";
            showNotConnected = true;
            statusMessage = "Backend request failed.";
        }
        finally
        {
            isLoading = false;
            if (string.IsNullOrEmpty(statusMessage))
                statusMessage = "Migration flow complete.";
            else
                executionStatusText = statusMessage;
        }
    }

