@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
@inject HttpClient Http
@using Microsoft.AspNetCore.Components.Forms
@using System.Collections.Generic
@using System.Linq
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
<PageTitle>.NET Migration Agent</PageTitle>

<!-- HEADER -->
<div class="ma-hero">
    <div class="ma-hero-content">
        <div class="ma-hero-left">
            <div class="ma-hero-brand">
                <div class="ma-hero-logo">🔄</div>
                <div>
                    <div class="ma-hero-title">.NET Migration Agent</div>
                    <div class="ma-hero-subtitle">
                        Intelligently migrate legacy .NET C# codebases to
                        <span class="ma-hero-highlight">next-generation .NET</span>
                        — powered by Microsoft AutoGen
                    </div>
                </div>
            </div>
            <div class="ma-hero-pills">
                <span class="hero-pill"><span class="pill-dot blue"></span>AutoGen</span>
                <span class="hero-pill"><span class="pill-dot purple"></span>CodeLlama</span>
                <span class="hero-pill"><span class="pill-dot green"></span>.NET 8+</span>
                <span class="hero-pill"><span class="pill-dot orange"></span>AI Powered</span>
            </div>
        </div>
    </div>
</div>

<div class="ma-container">

    <!-- SECTION 1: VERSION SELECTOR -->
    <div class="ma-card">
        <div class="ma-card-header">
            <div class="ma-card-title"><span>🎯</span> Migration Path</div>
        </div>
        <div class="ma-card-body">
            <div class="version-row">
                <div class="version-group">
                    <label>From Version</label>
                    <select class="version-select" @bind="fromVersion" @bind:after="CheckCompat">
                        <option>.NET Framework 4.5</option>
                        <option>.NET Framework 4.6</option>
                        <option>.NET Framework 4.7</option>
                        <option selected>.NET Framework 4.8</option>
                        <option>.NET Core 3.1</option>
                        <option>.NET 5</option>
                        <option>.NET 6</option>
                        <option>.NET 7</option>
                    </select>
                </div>
                <div class="version-arrow">→</div>
                <div class="version-group">
                    <label>To Version</label>
                    <select class="version-select" @bind="toVersion" @bind:after="CheckCompat">
                        <option>.NET 6</option>
                        <option>.NET 7</option>
                        <option selected>.NET 8</option>
                        <option>.NET 9</option>
                    </select>
                </div>
            </div>

            @if (showCompat)
            {
                <div class="compat-matrix @compatClass">
                    <div class="compat-left">
                        <div class="compat-status-icon">@compatIcon</div>
                        <div class="compat-status-title">@compatTitle</div>
                        <div class="compat-status-msg">@compatMsg</div>
                    </div>
                    <div class="compat-right">
                        <div class="compat-metric">
                            <span class="cm-label">Effort</span>
                            <div class="cm-bar"><div class="cm-fill effort" style="width:@effortPct%"></div></div>
                            <span class="cm-val">@effortLabel</span>
                        </div>
                        <div class="compat-metric">
                            <span class="cm-label">Risk</span>
                            <div class="cm-bar"><div class="cm-fill risk" style="width:@riskPct%"></div></div>
                            <span class="cm-val">@riskLabel</span>
                        </div>
                        <div class="compat-metric">
                            <span class="cm-label">Gap</span>
                            <div class="cm-bar"><div class="cm-fill gap" style="width:@gapPct%"></div></div>
                            <span class="cm-val">@versionGap versions</span>
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(recommendedPath))
                {
                    <div class="compat-recommendation">
                        <span>💡</span>
                        <span>@recommendedPath</span>
                    </div>
                }
            }
        </div>
    </div>

    <!-- SECTION 2: UPLOAD + CONTROLS -->
    <div class="two-col">
        <div class="ma-card">
            <div class="ma-card-header">
                <div class="ma-card-title"><span>📁</span> Upload Source</div>
            </div>
            <div class="ma-card-body">
                <!-- TAB SWITCHER -->
                <div class="upload-tabs">
                    <button class="upload-tab @(uploadTab=="local"?"active":"")" @onclick="SetTabLocal">📂 Local File</button>
                    <button class="upload-tab @(uploadTab=="github"?"active":"")" @onclick="SetTabGithub">🔗 GitHub URL</button>
                </div>

                @if (uploadTab == "local")
                {
                <div class="upload-zone @(isDrag?"drag":"")"
                     @ondragover:preventDefault="true"
                     @ondragover="()=>isDrag=true"
                     @ondragleave="()=>isDrag=false"
                     @ondrop="HandleDrop">
                    <div class="upload-icon">📦</div>
                    <h3>Drop files or folders here</h3>
                    <p>Supports .sln, .csproj, .cs, .zip files</p>
                    <InputFile id="fileInput" OnChange="HandleFileSelected" multiple style="display:none" />
                    <button class="browse-btn" @onclick="OpenFilePicker">Browse Files</button>
                </div>
                @if (files.Count > 0)
                {
                    <div class="file-list">
                        @foreach (var f in files)
                        {
                            <div class="file-item">
                                <span>@GetFileIcon(f.Name)</span>
                                <span class="fn">@f.Name</span>
                                <span class="fs">@FormatSize(f.Size)</span>
                                <button class="file-remove" @onclick="()=>RemoveFile(f)">✕</button>
                            </div>
                        }
                    </div>
                    <div style="margin-top:10px;font-size:12px;color:var(--text2);">
                        @files.Count file(s) selected
                    </div>
                }
                }
                else
                {
                <div class="github-input-area">
                    <div class="github-input-row">
                        <span class="github-icon">🔗</span>
                        <input class="github-input" type="text" placeholder="https://github.com/owner/repo"
                               @bind="githubUrl" @bind:event="oninput" />
                    </div>
                    <button class="browse-btn" style="width:100%;margin-top:10px;" @onclick="FetchGithubRepo"
                            disabled="@(isFetchingGithub || string.IsNullOrWhiteSpace(githubUrl))">
                        @if (isFetchingGithub)
                        {
                            <span>⏳ Fetching...</span>
                        }
                        else
                        {
                            <span>⬇️ Fetch Repository</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(githubFetchStatus))
                    {
                        <div class="github-status @(githubFetchSuccess?"success":"error")">
                            @(githubFetchSuccess ? "✅" : "❌") @githubFetchStatus
                        </div>
                    }
                </div>
                }
            </div>
        </div>

        <div class="ma-card">
            <div class="ma-card-header">
                <div class="ma-card-title"><span>⚙️</span> Migration Controls</div>
            </div>
            <div class="ma-card-body">
                <div style="font-size:11px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Migration Scope</div>
                <div class="scope-grid">
                    @foreach (var s in scopes)
                    {
                        <div class="scope-card @(s.Value?"on":"")" @onclick="()=>ToggleScope(s.Key)">
                            <div class="si">@scopeIcons[s.Key]</div>
                            <div class="sl">@s.Key</div>
                        </div>
                    }
                    <div class="scope-card @(isFullMigration?"on full":"")" @onclick="ToggleFullMigration"
                         style="grid-column:span 3;">
                        <div class="si">🚀</div>
                        <div class="sl">Full Migration</div>
                    </div>
                </div>

                <div class="adv-toggle" @onclick="()=>showAdvanced=!showAdvanced">
                    <span>⚙️ Advanced Settings</span>
                    <span>@(showAdvanced?"▲":"▼")</span>
                </div>

                @if (showAdvanced)
                {
                    <div class="adv-body">
                        <div class="ctrl-row">
                            <label>Language Target</label>
                            <select class="ctrl-select" @bind="langTarget">
                                <option>C# 10</option>
                                <option>C# 11</option>
                                <option selected>C# 12</option>
                            </select>
                        </div>
                        <div class="ctrl-row">
                            <label>Output Format</label>
                            <select class="ctrl-select" @bind="outputFmt">
                                <option selected>Web API + Services</option>
                                <option>Minimal API</option>
                                <option>MVC</option>
                                <option>Blazor</option>
                            </select>
                        </div>
                        <div class="ctrl-row">
                            <label>Execution Style</label>
                            <select class="ctrl-select" @bind="execStyle">
                                <option selected>Autonomous with review gates</option>
                                <option>Fully autonomous</option>
                                <option>Manual approval each step</option>
                            </select>
                        </div>
                    </div>
                }

                <button class="run-btn" @onclick="RunMigration" disabled="@(files.Count==0 || isLoading)">
                    <span>▶</span><span>Run Migration</span>
                </button>
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div style="margin-top:8px;font-size:13px;color:var(--text2);">@statusMessage</div>
                }
                @if (files.Count == 0)
                {
                    <div style="margin-top:8px;font-size:12px;color:var(--text2);text-align:center;">
                        Please upload files to enable migration
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- BACKEND NOT CONNECTED NOTICE -->
    @if (showNotConnected)
    {
        <div class="ma-card" style="border-color:rgba(255,140,0,0.4);animation:fadeIn 0.4s ease">
            <div class="ma-card-body" style="display:flex;align-items:center;gap:14px;padding:18px 20px;">
                <span style="font-size:28px;">🔌</span>
                <div>
                    <div style="font-weight:700;font-size:14px;color:var(--orange);">Backend Not Connected</div>
                    <div style="font-size:13px;color:var(--text2);margin-top:4px;">
                        Could not reach the backend. Please ensure the API is running and try again.
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- SECTION 3: EXECUTION PROGRESS -->
    <div class="ma-card">
        <div class="ma-card-header">
            <div class="ma-card-title"><span>🔄</span> Execution Progress</div>
                <span class="section-status">@executionStatusText</span>
        </div>
        <div class="ma-card-body">
            <div class="stepper">
                <div class="stepper-progress" style="width:@GetStepperProgressWidth()"></div>
                @foreach (var s in steps)
                {
                    <div class="step-item">
                        <div class="step-circle @stepStates[s.N - 1]">
                            <span>@(stepStates[s.N-1]=="completed" ? "✓" : s.N.ToString())</span>
                        </div>
                        <div class="step-label @stepStates[s.N - 1]">@s.Name</div>
                        <div class="step-sub">@stepSubtitles[s.N - 1]</div>
                    </div>
                }
            </div>
            <div class="terminal">
                @if (string.IsNullOrEmpty(terminalOutput))
                {
                    <div class="empty-terminal">
                        <span style="color:var(--text2);font-size:13px;">
                            Terminal output will appear here when migration runs...
                        </span>
                        <span class="t-cursor"></span>
                    </div>
                }
                else
                {
                    <pre>@terminalOutput</pre>
                }
            </div>
        </div>
    </div>

    <!-- SECTION 4: FINDINGS + ACTIONS -->
    <div class="two-col">
        <div class="ma-card">
            <div class="ma-card-header">
                <div class="ma-card-title"><span>🔍</span> Key Findings</div>
                <span class="section-status">Pending analysis</span>
            </div>
            <div class="ma-card-body">
                <div class="findings-summary">
                    <div class="f-badge critical">
                        <div class="fc">@findingsCritical.Count</div>
                        <div class="fl">Critical</div>
                    </div>
                    <div class="f-badge warning">
                        <div class="fc">@findingsWarnings.Count</div>
                        <div class="fl">Warnings</div>
                    </div>
                    <div class="f-badge info">
                        <div class="fc">@findingsInfo.Count</div>
                        <div class="fl">Info</div>
                    </div>
                </div>
                @if (findingsCritical.Count == 0 && findingsWarnings.Count == 0 && findingsInfo.Count == 0)
                {
                    <div class="empty-state">
                        <span>🔍</span>
                        <p>Findings will appear here after the agent analyzes your code</p>
                    </div>
                }
                else
                {
                    <div class="findings-list">
                        @foreach (var item in findingsCritical)
                        {
                            <div class="finding-item critical">⚠️ @item</div>
                        }
                        @foreach (var item in findingsWarnings)
                        {
                            <div class="finding-item warning">⚠ @item</div>
                        }
                        @foreach (var item in findingsInfo)
                        {
                            <div class="finding-item info">ℹ️ @item</div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="ma-card">
            <div class="ma-card-header">
                <div class="ma-card-title"><span>🤖</span> Autonomous Actions</div>
                    <span class="section-status">@(currentStep == 0 ? "Pending" : stepSubtitles[currentStep - 1])</span>
            </div>
            <div class="ma-card-body">
                <div class="action-list">
                    @for (int i = 0; i < autonomousActions.Count; i++)
                    {
                        var state = actionStates[i];
                        <div class="a-item @state">
                            <span class="a-icon">@GetActionIcon(i)</span>
                            <span class="a-text">@autonomousActions[i]</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- SECTION 5: GENERATED OUTPUTS -->
    <div class="ma-card">
        <div class="ma-card-header">
            <div class="ma-card-title"><span>📦</span> Generated Outputs</div>
            <span class="section-status">@(outputsReady.Values.Any(v => v) ? "Ready" : "Available after migration completes")</span>
        </div>
        <div class="ma-card-body">
            <div class="outputs-grid">
                <div class="out-card @(outputsReady["Migration Summary"] ? string.Empty : "disabled")" @onclick="OpenMigrationSummary">
                    <div class="out-icon">📄</div>
                    <div class="out-title">Migration Summary</div>
                    <div class="out-desc">Architecture, scope, blockers</div>
                </div>
                <div class="out-card @(outputsReady["Converted Code"] ? string.Empty : "disabled")" @onclick="OpenConvertedCode">
                    <div class="out-icon">💻</div>
                    <div class="out-title">Converted Code</div>
                    <div class="out-desc">.NET 8 Web API + Services</div>
                </div>
                <div class="out-card @(outputsReady["Dependency Map"] ? string.Empty : "disabled")" @onclick="OpenDependencyMap">
                    <div class="out-icon">📦</div>
                    <div class="out-title">Dependency Map</div>
                    <div class="out-desc">Legacy to modern packages</div>
                </div>
                <div class="out-card @(outputsReady["Manual Fix List"] ? string.Empty : "disabled")" @onclick="OpenManualFix">
                    <div class="out-icon">⚠️</div>
                    <div class="out-title">Manual Fix List</div>
                    <div class="out-desc">Developer intervention needed</div>
                </div>
                <div class="out-card @(outputsReady["Validation Report"] ? string.Empty : "disabled")" @onclick="OpenValidationReport">
                    <div class="out-icon">✅</div>
                    <div class="out-title">Validation Report</div>
                    <div class="out-desc">Build issues, syntax gaps</div>
                </div>
                <div class="out-card @(outputsReady["Change Log"] ? string.Empty : "disabled")" @onclick="OpenChangeLog">
                    <div class="out-icon">📝</div>
                    <div class="out-title">Change Log</div>
                    <div class="out-desc">Full transformation log</div>
                </div>
            </div>
            @if (migratedCount > 0)
            {
                <div style="margin-top:20px;text-align:center;">
                    <button class="run-btn" @onclick="DownloadMigratedProject" style="background:linear-gradient(135deg, #28a745, #20c997);">
                        <span>📥</span><span>Download Migrated Project</span>
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- SECTION 6: REVIEW GATE -->
    <div class="review-gate @(reviewGateReady ? "" : "disabled-gate")">
        <div class="rg-header" style="opacity:@(reviewGateReady ? "1" : "0.6");">
            🔍 Review Gate — @reviewGateMessage
        </div>
        <div class="rg-body">
            <div class="rg-checks">
                <div class="rg-check" style="opacity:0.5;">⏳ Approve transformed controllers and service layer</div>
                <div class="rg-check" style="opacity:0.5;">⏳ Validate dependency replacements before final packaging</div>
                <div class="rg-check" style="opacity:0.5;">⏳ Review unresolved issues requiring manual code fixes</div>
            </div>
            <div class="rg-actions">
                <button class="approve-btn" disabled="@(!reviewGateReady)" style="opacity:@(reviewGateReady ? "1" : "0.4");cursor:@(reviewGateReady ? "pointer" : "not-allowed");">✅ Approve</button>
                <button class="changes-btn" disabled="@(!reviewGateReady)" style="opacity:@(reviewGateReady ? "1" : "0.4");cursor:@(reviewGateReady ? "pointer" : "not-allowed");">🔄 Request Changes</button>
            </div>
        </div>
    </div>

    <!-- DETAIL VIEW OVERLAY -->
    @if (!string.IsNullOrEmpty(currentDetail))
    {
        <div class="detail-overlay" style="animation:fadeIn 0.3s ease">
            <div class="detail-header">
                <button class="back-btn" @onclick="CloseDetail">← Back</button>
                <div class="detail-title">@GetDetailTitle()</div>
            </div>
            <div class="detail-body">
                @if (currentDetail == "migration-summary")
                {
                    <div class="detail-section">
                        <div class="detail-meta-row">
                            <span class="detail-badge blue">From: @fromVersion</span>
                            <span class="detail-badge green">To: @toVersion</span>
                            <span class="detail-badge purple">@migratedCount files migrated</span>
                        </div>
                        <div class="detail-content">@analysisSummary</div>
                    </div>
                }
                else if (currentDetail == "converted-code")
                {
                    @foreach (var f in migratedFiles)
                    {
                        <div class="detail-file-block">
                            <div class="detail-file-name">📄 @f.Key</div>
                            <pre class="detail-code">@f.Value</pre>
                        </div>
                    }
                }
                else if (currentDetail == "dependency-map")
                {
                    <div class="detail-section">
                        <p style="color:var(--text2);margin-bottom:16px;">Packages detected and updated during migration:</p>
                        @foreach (var dep in dependencyMap)
                        {
                            <div class="dep-row">
                                <span class="dep-old">📦 @dep.Key</span>
                                <span class="dep-arrow">→</span>
                                <span class="dep-new">✅ @dep.Value</span>
                            </div>
                        }
                        @if (!dependencyMap.Any())
                        {
                            <div class="empty-state"><span>📦</span><p>No dependency changes detected.</p></div>
                        }
                    </div>
                }
                else if (currentDetail == "manual-fix")
                {
                    <div class="detail-section">
                        @if (findingsCritical.Any())
                        {
                            <div style="margin-bottom:12px;font-weight:700;color:var(--red);">Critical Issues</div>
                            @foreach (var item in findingsCritical)
                            {
                                <div class="detail-issue critical">❌ @item</div>
                            }
                        }
                        @if (findingsWarnings.Any())
                        {
                            <div style="margin:12px 0;font-weight:700;color:var(--orange);">Warnings</div>
                            @foreach (var item in findingsWarnings)
                            {
                                <div class="detail-issue warning">⚠️ @item</div>
                            }
                        }
                        @if (!findingsCritical.Any() && !findingsWarnings.Any())
                        {
                            <div class="empty-state"><span>✅</span><p>No manual fixes required!</p></div>
                        }
                    </div>
                }
                else if (currentDetail == "validation-report")
                {
                    <div class="detail-section">
                        <div class="detail-badge @(validationSummary == "Build succeeded." ? "green" : validationSummary == "Build skipped." ? "blue" : "red")" style="margin-bottom:16px;display:inline-block;">
                            @(validationSummary == "Build succeeded." ? "✅ Build Passed" : validationSummary == "Build skipped." ? "⚠️ Validation Skipped — Run dotnet build locally" : "❌ Build Failed")
                        </div>
                        <pre class="detail-code">@validationOutput</pre>
                    </div>
                }
                else if (currentDetail == "change-log")
                {
                    <div class="detail-section">
                        <p style="color:var(--text2);margin-bottom:16px;">@reportSummary</p>
                        @foreach (var f in migratedFiles)
                        {
                            <div class="dep-row">
                                <span>📄 @f.Key</span>
                                <span class="dep-new">✅ Migrated to .NET 8</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

</div>

@code {
    string fromVersion = ".NET Framework 4.8";
    string toVersion = ".NET 8";
    bool showCompat = true;
    string compatClass = "warning";
    string compatIcon = "⚠️";
    string compatTitle = "Compatible with Breaking Changes";
    string compatMsg = "Migration path available. Review breaking changes before proceeding.";
    int versionGap = 2;
    int effortPct = 60;
    int riskPct = 40;
    int gapPct = 40;
    string effortLabel = "Medium";
    string riskLabel = "Low";
    string recommendedPath = "";

    // Version order map
    Dictionary<string, int> versionOrder = new()
    {
        [".NET Framework 4.5"] = 1,
        [".NET Framework 4.6"] = 2,
        [".NET Framework 4.7"] = 3,
        [".NET Framework 4.8"] = 4,
        [".NET Core 3.1"] = 5,
        [".NET 5"] = 6,
        [".NET 6"] = 7,
        [".NET 7"] = 8,
        [".NET 8"] = 9,
        [".NET 9"] = 10
    };

    void CheckCompat()
    {
        showCompat = true;
        recommendedPath = "";

        int fromIdx = versionOrder.ContainsKey(fromVersion) ? versionOrder[fromVersion] : 0;
        int toIdx = versionOrder.ContainsKey(toVersion) ? versionOrder[toVersion] : 0;
        versionGap = Math.Abs(toIdx - fromIdx);
        gapPct = Math.Min(versionGap * 15, 100);

        // Same version
        if (fromVersion == toVersion)
        {
            compatClass = "error";
            compatIcon = "🚫";
            compatTitle = "Cannot Migrate to Same Version";
            compatMsg = "Source and target versions are identical. Please select a different target.";
            effortPct = 0; riskPct = 0;
            effortLabel = "None"; riskLabel = "None";
            return;
        }

        // Downgrade
        if (toIdx < fromIdx)
        {
            compatClass = "error";
            compatIcon = "🚫";
            compatTitle = "Downgrade Not Supported";
            compatMsg = "Migrating to an older version is not supported. Please select a newer target version.";
            effortPct = 0; riskPct = 100;
            effortLabel = "N/A"; riskLabel = "High";
            return;
        }

        // Smooth - 1 version gap
        if (versionGap == 1)
        {
            compatClass = "success";
            compatIcon = "✅";
            compatTitle = "Smooth Migration — Minimal Changes";
            compatMsg = $"Direct upgrade from {fromVersion} to {toVersion}. Low effort, minimal breaking changes expected.";
            effortPct = 20; riskPct = 10;
            effortLabel = "Low"; riskLabel = "Low";
            return;
        }

        // Medium - 2-3 version gap
        if (versionGap <= 3)
        {
            compatClass = "warning";
            compatIcon = "⚠️";
            compatTitle = "Compatible with Breaking Changes";
            compatMsg = $"Migration from {fromVersion} to {toVersion} is possible. Some breaking changes and manual fixes required.";
            effortPct = 60; riskPct = 40;
            effortLabel = "Medium"; riskLabel = "Low";
            return;
        }

        // Complex - 4+ version gap
        compatClass = "error";
        compatIcon = "🔴";
        compatTitle = "Complex Migration — High Effort";
        compatMsg = $"Large version gap detected ({versionGap} versions). Significant breaking changes and rewrites expected.";
        effortPct = 90; riskPct = 80;
        effortLabel = "High"; riskLabel = "High";
        recommendedPath = $"💡 Recommended: Migrate step by step — {fromVersion} → .NET 6 → .NET 8 → {toVersion}";
    }

    string currentDetail = string.Empty;
