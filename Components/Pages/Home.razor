    string GetStepperProgressWidth()
    {
        int completed = stepStates.Count(s => s == "completed");
        int active = stepStates.Any(s => s == "active") ? 1 : 0;
        // Each step gap is 25% (4 gaps for 5 steps)
        double pct = (completed + active * 0.5) * 25.0;
        pct = Math.Min(pct, 100);
        // Convert to actual pixel calc — stepper line goes from left:40px to right:40px
        return $"calc((100% - 80px) * {pct / 100.0:F2})";
    }

    void SetStep(int step, string subtitle)
    {
        for (int i = 0; i < stepStates.Count; i++)
        {
            stepStates[i] = i < step - 1 ? "completed" : "pending";
            stepSubtitles[i] = i < step - 1 ? "Done" : "Waiting";
        }
        if (step >= 1 && step <= stepStates.Count)
        {
            stepStates[step - 1] = "active";
            stepSubtitles[step - 1] = subtitle;
        }
        currentStep = step;
        executionStatusText = subtitle;
        StateHasChanged();
    }

    void SetActionStage(int step)
    {
        for (int i = 0; i < actionStates.Count; i++)
        {
            actionStates[i] = "pending";
        }
        if (step == 1)
        {
            actionStates[0] = "active";
        }
        else if (step == 2)
        {
            actionStates[0] = "completed";
            actionStates[1] = "active";
        }
        else if (step == 3)
        {
            actionStates[0] = "completed";
            actionStates[1] = "completed";
            actionStates[2] = "active";
        }
        else if (step == 4)
        {
            actionStates[0] = "completed";
            actionStates[1] = "completed";
            actionStates[2] = "completed";
            actionStates[3] = "active";
        }
        else if (step == 5)
        {
            actionStates[0] = "completed";
            actionStates[1] = "completed";
            actionStates[2] = "completed";
            actionStates[3] = "completed";
            actionStates[4] = "active";
        }
        else if (step >= 6)
        {
            for (int i = 0; i < actionStates.Count; i++)
                actionStates[i] = "completed";
        }
    }

    string GetActionIcon(int index)
    {
        return actionStates[index] switch
        {
            "completed" => "✅",
            "active" => "⏳",
            _ => "⏸️",
        };
    }

